<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;

// ─── CONFIG ───────────────────────────────────────────────────────────────────
const CONFIG = {
  clientId:  "613928f8-0497-47ea-bb0f-c1725a1f156a",
  tenantId:  "ec357a32-5b85-438d-a765-ae33c8eb13b7",
  siteId:    "825ac03b-8ba9-4336-a5a1-63ea999f0d7e",
  siteUrl:   "https://distributedei.sharepoint.com/sites/Buildingaconnectedfuture",
  lists: {
    rfi: "DEI-RFI-Submittal-Tracker",
  }
};

// ─── MSAL SETUP ───────────────────────────────────────────────────────────────
const msalConfig = {
  auth: {
    clientId: CONFIG.clientId,
    authority: `https://login.microsoftonline.com/${CONFIG.tenantId}`,
    redirectUri: window.location.origin,
  },
  cache: { cacheLocation: "sessionStorage" }
};

const msalInstance = new msal.PublicClientApplication(msalConfig);

const GRAPH_SCOPES = ["Sites.Selected", "Files.Read.All", "User.Read"];

// ─── GRAPH API CLIENT ─────────────────────────────────────────────────────────
async function getToken() {
  const accounts = msalInstance.getAllAccounts();
  if (accounts.length === 0) throw new Error("Not signed in");
  try {
    const result = await msalInstance.acquireTokenSilent({
      scopes: GRAPH_SCOPES,
      account: accounts[0]
    });
    return result.accessToken;
  } catch (e) {
    const result = await msalInstance.acquireTokenPopup({ scopes: GRAPH_SCOPES });
    return result.accessToken;
  }
}

async function graphGet(path) {
  const token = await getToken();
  const res = await fetch(`https://graph.microsoft.com/v1.0${path}`, {
    headers: { Authorization: `Bearer ${token}` }
  });
  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || `Graph API error: ${res.status}`);
  }
  return res.json();
}

async function graphPost(path, body) {
  const token = await getToken();
  const res = await fetch(`https://graph.microsoft.com/v1.0${path}`, {
    method: "POST",
    headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || `Graph API error: ${res.status}`);
  }
  return res.json();
}

async function graphPatch(path, body) {
  const token = await getToken();
  const res = await fetch(`https://graph.microsoft.com/v1.0${path}`, {
    method: "PATCH",
    headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || `Graph API error: ${res.status}`);
  }
  return res.json();
}

// ─── SHAREPOINT LIST HELPERS ──────────────────────────────────────────────────
const SITE_PATH = `/sites/${CONFIG.siteId}`;

async function getListItems(listName, filter = "") {
  let path = `${SITE_PATH}/lists/${listName}/items?expand=fields&$top=500`;
  if (filter) path += `&$filter=${encodeURIComponent(filter)}`;
  const data = await graphGet(path);
  return (data.value || []).map(i => ({ id: i.id, ...i.fields }));
}

async function createListItem(listName, fields) {
  return graphPost(`${SITE_PATH}/lists/${listName}/items`, { fields });
}

async function updateListItem(listName, itemId, fields) {
  return graphPatch(`${SITE_PATH}/lists/${listName}/items/${itemId}/fields`, fields);
}

// ─── HELPERS ──────────────────────────────────────────────────────────────────
function statusBadge(status) {
  const map = {
    "Draft": "badge-draft",
    "Submitted": "badge-submitted",
    "In Review": "badge-review",
    "Returned - Revise": "badge-returned",
    "Approved": "badge-approved",
    "Rejected": "badge-rejected",
    "Closed": "badge-closed",
  };
  return <span className={`badge ${map[status] || "badge-draft"}`}>{status || "—"}</span>;
}

function bicChip(bic) {
  const map = { Engineering:"bic-eng", Construction:"bic-con", PM:"bic-pm", Owner:"bic-owner", Vendor:"bic-vendor", "AHJ/Utility":"bic-ahj" };
  const icons = { Engineering:"⚙️", Construction:"🏗️", PM:"📋", Owner:"👤", Vendor:"📦", "AHJ/Utility":"🏛️" };
  return <span className={`bic ${map[bic]||"bic-vendor"}`}>{icons[bic]||"•"} {bic||"—"}</span>;
}

function agingCell(dueDateStr) {
  if (!dueDateStr) return <span style={{color:"#475569"}}>No date</span>;
  const due = new Date(dueDateStr);
  const today = new Date();
  const days = Math.floor((today - due) / 86400000);
  if (days <= 0) return <span className="aging-ok">On Track</span>;
  if (days < 7)  return <span className="aging-warn">{days}d overdue</span>;
  return <span className="aging-danger">{days}d overdue ⚠</span>;
}

function formatDate(d) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("en-US", { month:"short", day:"numeric", year:"numeric" });
}

// ─── MODALS ───────────────────────────────────────────────────────────────────
function Modal({ title, onClose, children }) {
  return (
    <div className="modal-overlay" onClick={e => e.target === e.currentTarget && onClose()}>
      <div className="modal">
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
          <div className="modal-title">{title}</div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>
        {children}
      </div>
    </div>
  );
}

function AddItemModal({ onClose, onSave }) {
  const [form, setForm] = useState({
    Title: "", Project: "", ItemType: "RFI", Number: "",
    Subject: "", Status: "Draft", BallInCourt: "Engineering",
    AssignedTo: "", DueDate: "", Description: "", EvidenceLink: ""
  });
  const [saving, setSaving] = useState(false);
  const set = (k, v) => setForm(f => ({...f, [k]: v}));

  const save = async () => {
    setSaving(true);
    try {
      await onSave(form);
      onClose();
    } catch(e) {
      alert("Error saving: " + e.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <Modal title="Add New RFI / Submittal" onClose={onClose}>
      <div className="form-group">
        <label className="form-label">Title</label>
        <input className="form-input" value={form.Title} onChange={e=>set("Title",e.target.value)} placeholder="Brief title..." />
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
        <div className="form-group">
          <label className="form-label">Project</label>
          <input className="form-input" value={form.Project} onChange={e=>set("Project",e.target.value)} placeholder="Project name" />
        </div>
        <div className="form-group">
          <label className="form-label">Type</label>
          <select className="form-select" value={form.ItemType} onChange={e=>set("ItemType",e.target.value)}>
            <option>RFI</option>
            <option>Submittal</option>
          </select>
        </div>
        <div className="form-group">
          <label className="form-label">Number</label>
          <input className="form-input" value={form.Number} onChange={e=>set("Number",e.target.value)} placeholder="RFI-001" />
        </div>
        <div className="form-group">
          <label className="form-label">Status</label>
          <select className="form-select" value={form.Status} onChange={e=>set("Status",e.target.value)}>
            {["Draft","Submitted","In Review","Returned - Revise","Approved","Rejected","Closed"].map(s=><option key={s}>{s}</option>)}
          </select>
        </div>
        <div className="form-group">
          <label className="form-label">Ball in Court</label>
          <select className="form-select" value={form.BallInCourt} onChange={e=>set("BallInCourt",e.target.value)}>
            {["Engineering","Construction","PM","Owner","Vendor","AHJ/Utility"].map(s=><option key={s}>{s}</option>)}
          </select>
        </div>
        <div className="form-group">
          <label className="form-label">Assigned To</label>
          <input className="form-input" value={form.AssignedTo} onChange={e=>set("AssignedTo",e.target.value)} placeholder="Name" />
        </div>
        <div className="form-group">
          <label className="form-label">Due Date</label>
          <input className="form-input" type="date" value={form.DueDate} onChange={e=>set("DueDate",e.target.value)} />
        </div>
        <div className="form-group">
          <label className="form-label">Subject</label>
          <input className="form-input" value={form.Subject} onChange={e=>set("Subject",e.target.value)} placeholder="Subject" />
        </div>
      </div>
      <div className="form-group">
        <label className="form-label">Description</label>
        <textarea className="form-textarea" value={form.Description} onChange={e=>set("Description",e.target.value)} placeholder="Details..." />
      </div>
      <div className="form-group">
        <label className="form-label">Evidence / SharePoint Link</label>
        <input className="form-input" value={form.EvidenceLink} onChange={e=>set("EvidenceLink",e.target.value)} placeholder="https://..." />
      </div>
      <div className="modal-actions">
        <button className="btn btn-ghost" onClick={onClose}>Cancel</button>
        <button className="btn btn-primary" onClick={save} disabled={saving || !form.Title}>
          {saving ? "Saving..." : "Save to SharePoint"}
        </button>
      </div>
    </Modal>
  );
}

function EditStatusModal({ item, onClose, onSave }) {
  const [status, setStatus] = useState(item.Status || "Draft");
  const [bic, setBic]       = useState(item.BallInCourt || "Engineering");
  const [saving, setSaving] = useState(false);

  const save = async () => {
    setSaving(true);
    try {
      await onSave(item.id, { Status: status, BallInCourt: bic });
      onClose();
    } catch(e) {
      alert("Error: " + e.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <Modal title={`Update — ${item.Title || item.Number}`} onClose={onClose}>
      <div className="form-group">
        <label className="form-label">Current Status</label>
        {statusBadge(item.Status)}
      </div>
      <div className="form-group">
        <label className="form-label">New Status</label>
        <select className="form-select" value={status} onChange={e=>setStatus(e.target.value)}>
          {["Draft","Submitted","In Review","Returned - Revise","Approved","Rejected","Closed"].map(s=><option key={s}>{s}</option>)}
        </select>
      </div>
      <div className="form-group">
        <label className="form-label">Ball in Court</label>
        <select className="form-select" value={bic} onChange={e=>setBic(e.target.value)}>
          {["Engineering","Construction","PM","Owner","Vendor","AHJ/Utility"].map(s=><option key={s}>{s}</option>)}
        </select>
      </div>
      <div className="modal-actions">
        <button className="btn btn-ghost" onClick={onClose}>Cancel</button>
        <button className="btn btn-primary" onClick={save} disabled={saving}>
          {saving ? "Saving..." : "Update in SharePoint"}
        </button>
      </div>
    </Modal>
  );
}

// ─── ENGINEERING LOG VIEW ─────────────────────────────────────────────────────
function EngineeringView() {
  const [items, setItems]       = useState([]);
  const [loading, setLoading]   = useState(true);
  const [error, setError]       = useState(null);
  const [success, setSuccess]   = useState(null);
  const [typeFilter, setType]   = useState("all");
  const [statusFilter, setStat] = useState("all");
  const [bicFilter, setBic]     = useState("all");
  const [modal, setModal]       = useState(null);
  const [selected, setSelected] = useState(null);

  const load = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const data = await getListItems(CONFIG.lists.rfi);
      setItems(data);
    } catch(e) {
      setError(e.message);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => { load(); }, [load]);

  const handleAdd = async (fields) => {
    await createListItem(CONFIG.lists.rfi, fields);
    setSuccess("Item added to SharePoint ✓");
    setTimeout(() => setSuccess(null), 3000);
    load();
  };

  const handleUpdate = async (itemId, fields) => {
    await updateListItem(CONFIG.lists.rfi, itemId, fields);
    setSuccess("Updated in SharePoint ✓");
    setTimeout(() => setSuccess(null), 3000);
    load();
  };

  const filtered = items.filter(i =>
    (typeFilter === "all" || i.ItemType === typeFilter) &&
    (statusFilter === "all" || i.Status === statusFilter) &&
    (bicFilter === "all" || i.BallInCourt === bicFilter)
  ).sort((a,b) => {
    if (!a.DueDate) return 1;
    if (!b.DueDate) return -1;
    return new Date(a.DueDate) - new Date(b.DueDate);
  });

  const overdue = items.filter(i => i.DueDate && new Date(i.DueDate) < new Date() && i.Status !== "Closed" && i.Status !== "Approved");

  return (
    <div>
      <div className="section-title">Engineering Log</div>
      <div className="section-sub">RFIs and Submittals — live from SharePoint</div>

      {error && <div className="error-banner">⚠️ {error}</div>}
      {success && <div className="success-banner">✅ {success}</div>}

      <div className="kpi-grid">
        <div className="kpi-card">
          <div className="kpi-label">Total Items</div>
          <div className="kpi-value">{items.length}</div>
          <div className="kpi-sub">In SharePoint list</div>
        </div>
        <div className={`kpi-card ${overdue.length > 0 ? "alert" : ""}`}>
          <div className="kpi-label">Overdue</div>
          <div className="kpi-value">{overdue.length}</div>
          <div className={`kpi-sub ${overdue.length > 0 ? "red" : "green"}`}>
            {overdue.length > 0 ? "Needs attention" : "All on track"}
          </div>
        </div>
        <div className="kpi-card">
          <div className="kpi-label">Open RFIs</div>
          <div className="kpi-value">{items.filter(i=>i.ItemType==="RFI"&&i.Status!=="Closed").length}</div>
          <div className="kpi-sub">{items.filter(i=>i.ItemType==="RFI").length} total</div>
        </div>
        <div className="kpi-card">
          <div className="kpi-label">Open Submittals</div>
          <div className="kpi-value">{items.filter(i=>i.ItemType==="Submittal"&&i.Status!=="Closed").length}</div>
          <div className="kpi-sub">{items.filter(i=>i.ItemType==="Submittal").length} total</div>
        </div>
      </div>

      <div className="table-wrap">
        <div className="table-header">
          <div className="table-title">Items ({filtered.length})</div>
          <div className="filters">
            <select className="filter-select" value={typeFilter} onChange={e=>setType(e.target.value)}>
              <option value="all">All Types</option>
              <option value="RFI">RFI</option>
              <option value="Submittal">Submittal</option>
            </select>
            <select className="filter-select" value={statusFilter} onChange={e=>setStat(e.target.value)}>
              <option value="all">All Statuses</option>
              {["Draft","Submitted","In Review","Returned - Revise","Approved","Rejected","Closed"].map(s=>
                <option key={s} value={s}>{s}</option>
              )}
            </select>
            <select className="filter-select" value={bicFilter} onChange={e=>setBic(e.target.value)}>
              <option value="all">All Ball-in-Court</option>
              {["Engineering","Construction","PM","Owner","Vendor","AHJ/Utility"].map(s=>
                <option key={s} value={s}>{s}</option>
              )}
            </select>
            <button className="btn btn-ghost btn-sm" onClick={load}>↺ Refresh</button>
            <button className="btn btn-primary btn-sm" onClick={()=>setModal("add")}>+ Add Item</button>
          </div>
        </div>

        {loading ? (
          <div className="loading">
            <div className="spinner" />
            <div>Loading from SharePoint...</div>
          </div>
        ) : filtered.length === 0 ? (
          <div className="empty-state">
            <div className="empty-icon">📋</div>
            <div style={{marginBottom:8}}>
              {items.length === 0 ? "No items in SharePoint yet." : "No items match the current filters."}
            </div>
            {items.length === 0 && (
              <button className="btn btn-primary" onClick={()=>setModal("add")}>+ Add First Item</button>
            )}
          </div>
        ) : (
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Type</th>
                <th>Title / Subject</th>
                <th>Project</th>
                <th>Status</th>
                <th>Ball in Court</th>
                <th>Assigned To</th>
                <th>Due Date</th>
                <th>Aging</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {filtered.map(item => (
                <tr key={item.id}>
                  <td><span style={{fontFamily:"monospace",color:"#60a5fa",fontSize:12}}>{item.Number||"—"}</span></td>
                  <td><span className="tag">{item.ItemType||"—"}</span></td>
                  <td>
                    <div style={{color:"#e2e8f0",fontWeight:500}}>{item.Title}</div>
                    {item.Subject && <div style={{color:"#64748b",fontSize:11,marginTop:2}}>{item.Subject}</div>}
                    {item.EvidenceLink && (
                      <a href={item.EvidenceLink} target="_blank" rel="noreferrer" style={{fontSize:11,color:"#60a5fa"}}>📎 Evidence</a>
                    )}
                  </td>
                  <td style={{color:"#94a3b8",fontSize:12}}>{item.Project||"—"}</td>
                  <td>{statusBadge(item.Status)}</td>
                  <td>{bicChip(item.BallInCourt)}</td>
                  <td style={{color:"#94a3b8",fontSize:13}}>{item.AssignedTo||"—"}</td>
                  <td style={{color:"#94a3b8",fontSize:13}}>{formatDate(item.DueDate)}</td>
                  <td>{agingCell(item.DueDate)}</td>
                  <td>
                    <button className="btn btn-ghost btn-sm" onClick={()=>{setSelected(item);setModal("edit");}}>
                      ✏️ Update
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

      {modal === "add" && <AddItemModal onClose={()=>setModal(null)} onSave={handleAdd} />}
      {modal === "edit" && selected && (
        <EditStatusModal item={selected} onClose={()=>setModal(null)} onSave={handleUpdate} />
      )}
    </div>
  );
}

// ─── OVERVIEW VIEW ────────────────────────────────────────────────────────────
function OverviewView({ user }) {
  const [stats, setStats] = useState(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    getListItems(CONFIG.lists.rfi).then(items => {
      setStats({
        total: items.length,
        overdue: items.filter(i => i.DueDate && new Date(i.DueDate) < new Date() && i.Status !== "Closed").length,
        rfis: items.filter(i => i.ItemType === "RFI").length,
        submittals: items.filter(i => i.ItemType === "Submittal").length,
        open: items.filter(i => !["Closed","Approved","Rejected"].includes(i.Status)).length,
      });
    }).catch(() => setStats(null)).finally(() => setLoading(false));
  }, []);

  return (
    <div>
      <div className="section-title">Welcome back, {user?.name?.split(" ")[0] || "there"} 👋</div>
      <div className="section-sub">DEI Project Truth — connected to SharePoint</div>

      <div style={{background:"#141720",border:"1px solid #1e2535",borderRadius:10,padding:16,marginBottom:24,display:"flex",alignItems:"center",gap:12}}>
        <span style={{fontSize:24}}>🔗</span>
        <div>
          <div style={{fontWeight:600,color:"#e2e8f0",fontSize:14}}>Connected to SharePoint</div>
          <div style={{color:"#64748b",fontSize:12}}>
            <a href={CONFIG.siteUrl} target="_blank" rel="noreferrer" style={{color:"#60a5fa"}}>
              {CONFIG.siteUrl}
            </a>
          </div>
        </div>
        <span style={{marginLeft:"auto",color:"#34d399",fontSize:13}}>● Live</span>
      </div>

      {loading ? (
        <div className="loading"><div className="spinner"/><div>Loading data...</div></div>
      ) : stats ? (
        <div className="kpi-grid">
          <div className="kpi-card">
            <div className="kpi-label">Total Tracked Items</div>
            <div className="kpi-value">{stats.total}</div>
            <div className="kpi-sub green">In SharePoint</div>
          </div>
          <div className={`kpi-card ${stats.overdue > 0 ? "alert" : ""}`}>
            <div className="kpi-label">Overdue</div>
            <div className="kpi-value">{stats.overdue}</div>
            <div className={`kpi-sub ${stats.overdue > 0 ? "red" : "green"}`}>
              {stats.overdue > 0 ? "Need attention" : "All on track"}
            </div>
          </div>
          <div className="kpi-card">
            <div className="kpi-label">Open Items</div>
            <div className="kpi-value">{stats.open}</div>
            <div className="kpi-sub">Active</div>
          </div>
          <div className="kpi-card">
            <div className="kpi-label">RFIs / Submittals</div>
            <div className="kpi-value">{stats.rfis} / {stats.submittals}</div>
            <div className="kpi-sub">Split</div>
          </div>
        </div>
      ) : (
        <div className="error-banner">Could not load stats — check SharePoint connection</div>
      )}

      <div style={{background:"#141720",border:"1px solid #1e2535",borderRadius:10,padding:20,marginTop:8}}>
        <div style={{fontWeight:600,marginBottom:12,color:"#e2e8f0"}}>📋 MVP Status</div>
        <div style={{display:"flex",flexDirection:"column",gap:8,fontSize:13}}>
          {[
            ["✅","Azure AD Authentication","Working — signed in as " + (user?.username||"you")],
            ["✅","SharePoint Connection","Connected to DEI site"],
            ["✅","RFI & Submittal Tracker","Live — read/write to SharePoint list"],
            ["🔜","Permit Matrix","Create DEI-Permit-Matrix list next"],
            ["🔜","BOM / Procurement","Create DEI-BOM-Procurement list next"],
            ["🔜","Invoicing","Create DEI-Invoices list next"],
            ["🔜","Closeout Tracker","Create DEI-Closeout list next"],
          ].map(([icon,label,sub]) => (
            <div key={label} style={{display:"flex",alignItems:"center",gap:10,padding:"8px 0",borderBottom:"1px solid #1e2535"}}>
              <span style={{fontSize:16}}>{icon}</span>
              <div>
                <div style={{color:"#e2e8f0",fontWeight:500}}>{label}</div>
                <div style={{color:"#64748b",fontSize:11}}>{sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ─── LOGIN SCREEN ─────────────────────────────────────────────────────────────
function LoginScreen({ onLogin }) {
  const [loading, setLoading] = useState(false);
  const [error, setError]     = useState(null);

  const login = async () => {
    setLoading(true);
    setError(null);
    try {
      await msalInstance.initialize();
      const result = await msalInstance.loginPopup({ scopes: GRAPH_SCOPES });
      onLogin(result.account);
    } catch(e) {
      setError(e.message);
      setLoading(false);
    }
  };

  return (
    <div className="login-screen">
      <div className="login-card">
        <div className="login-logo">🏗️</div>
        <div className="login-title">DEI Project Truth</div>
        <div className="login-sub">Sign in with your Distributed Energy Infrastructure Microsoft account to access project data.</div>
        {error && <div className="error-banner" style={{marginBottom:16,textAlign:"left"}}>⚠️ {error}</div>}
        <button className="ms-btn" onClick={login} disabled={loading}>
          <svg width="20" height="20" viewBox="0 0 21 21" fill="none">
            <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
            <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
            <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
            <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
          </svg>
          {loading ? "Signing in..." : "Sign in with Microsoft"}
        </button>
      </div>
    </div>
  );
}

// ─── COMING SOON PLACEHOLDER ──────────────────────────────────────────────────
function ComingSoon({ title, listName }) {
  return (
    <div>
      <div className="section-title">{title}</div>
      <div className="section-sub">Coming next — requires SharePoint list setup</div>
      <div style={{background:"#141720",border:"1px solid #1e2535",borderRadius:10,padding:32,textAlign:"center"}}>
        <div style={{fontSize:40,marginBottom:12}}>🔜</div>
        <div style={{fontWeight:600,color:"#e2e8f0",marginBottom:8}}>Create the SharePoint list to enable this view</div>
        <div style={{color:"#64748b",fontSize:13,marginBottom:20}}>
          Go to your SharePoint site → New → List → Blank list → name it <code style={{background:"#1e2535",padding:"2px 6px",borderRadius:4,color:"#60a5fa"}}>{listName}</code>
        </div>
        <a href={CONFIG.siteUrl} target="_blank" rel="noreferrer" className="btn btn-primary">
          Open SharePoint Site →
        </a>
      </div>
    </div>
  );
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────────
function App() {
  const [user, setUser]   = useState(null);
  const [view, setView]   = useState("overview");
  const [ready, setReady] = useState(false);

  useEffect(() => {
    msalInstance.initialize().then(() => {
      // Check if already signed in
      const accounts = msalInstance.getAllAccounts();
      if (accounts.length > 0) setUser(accounts[0]);
      setReady(true);
    });
  }, []);

  if (!ready) return (
    <div className="login-screen">
      <div className="loading"><div className="spinner"/><div>Initializing...</div></div>
    </div>
  );

  if (!user) return <LoginScreen onLogin={setUser} />;

  const navItems = [
    { section: "Project" },
    { id: "overview",    icon: "🏠", label: "Overview" },
    { section: "Logs" },
    { id: "engineering", icon: "⚙️", label: "Engineering Log" },
    { id: "owner",       icon: "👤", label: "Owner Log" },
    { id: "permits",     icon: "🏛️", label: "Permits" },
    { id: "closeout",    icon: "📋", label: "Closeout" },
  ];

  const viewTitles = {
    overview: "Overview", engineering: "Engineering Log",
    owner: "Owner Log", permits: "Permit Matrix", closeout: "Closeout"
  };

  return (
    <div className="app">
      <div className="sidebar">
        <div className="sidebar-logo">
          <div className="logo-text">DEI Project Truth</div>
          <div className="logo-sub">PMO Control Plane</div>
        </div>
        <div className="nav">
          {navItems.map((item, i) => {
            if (item.section) return <div key={i} className="nav-section">{item.section}</div>;
            return (
              <div key={item.id} className={`nav-item ${view===item.id?"active":""}`} onClick={()=>setView(item.id)}>
                <span>{item.icon}</span>
                <span>{item.label}</span>
                {item.badge > 0 && <span className={`nav-badge ${item.badgeType||""}`}>{item.badge}</span>}
              </div>
            );
          })}
        </div>
        <div className="sidebar-footer">
          <div>👤 {user.name || user.username}</div>
          <div style={{marginTop:4,fontSize:11,color:"#334155"}}>Distributed Energy Infrastructure</div>
          <button
            className="btn btn-ghost btn-sm"
            style={{marginTop:8,width:"100%",justifyContent:"center"}}
            onClick={()=>{ msalInstance.logoutPopup(); setUser(null); }}
          >Sign out</button>
        </div>
      </div>

      <div className="main">
        <div className="topbar">
          <div className="topbar-title">{viewTitles[view]}</div>
          <div className="topbar-actions">
            <span style={{fontSize:12,color:"#34d399"}}>● Connected to SharePoint</span>
          </div>
        </div>
        <div className="content">
          {view === "overview"    && <OverviewView user={user} />}
          {view === "engineering" && <EngineeringView />}
          {view === "owner"       && <ComingSoon title="Owner Log" listName="DEI-BOM-Procurement" />}
          {view === "permits"     && <ComingSoon title="Permit Matrix" listName="DEI-Permit-Matrix" />}
          {view === "closeout"    && <ComingSoon title="Closeout Tracker" listName="DEI-Closeout-Items" />}
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
